# Backend production environment
# Copy to backend/.env for deployment
NODE_ENV=production
PORT=3001

# Public frontend deployment URL
FRONTEND_URL=https://app.example.com
APP_BASE_URL=https://app.example.com

# Allowed origins for CORS
CORS_ORIGINS=https://app.example.com

# Database / Redis / AI runtime
DATABASE_URL="mysql://examtrust:CHANGE_ME@db:3306/examtrust"
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

AI_PROVIDER=ollama
AI_OLLAMA_URL=http://ollama:11434
AI_OLLAMA_MODEL=gemma3:4b
AI_OLLAMA_TEMPERATURE=0.2
AI_OLLAMA_TOP_P=0.85
AI_OLLAMA_REPEAT_PENALTY=1.1
AI_OLLAMA_NUM_CTX=8192
AI_APP_NAME=ExamTrust
AI_DEFAULT_LANGUAGE=vi

JWT_SECRET=CHANGE_ME
JWT_EXPIRES_IN=360d
