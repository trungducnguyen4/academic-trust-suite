# Backend environment example (DO NOT commit real secrets)
NODE_ENV=development
PORT=3001

# Frontend URL used to build exam links
FRONTEND_URL=http://localhost:8080
APP_BASE_URL=http://localhost:5173

# Comma-separated list of allowed frontend origins for CORS
CORS_ORIGINS=http://localhost:8080,http://localhost:5173,http://localhost:3000

# SMTP example (SendGrid recommended for production)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=<SENDGRID_API_KEY>
EMAIL_FROM="ExamTrust <no-reply@yourdomain.com>"
MAILER_ALLOW_SELF_SIGNED=false

# IP retention: number of days to keep IP/proctoring data before pseudonymize/delete
IP_RETENTION_DAYS=90

# Purge behavior
# PSEUDONYMIZE=true  -> replace IPs with one-way hash (recommended)
# PSEUDONYMIZE_SALT=<secret stored in secret manager>
# DRY_RUN=true -> script will only report counts but not modify data

DATABASE_URL="mysql://root@127.0.0.1:3306/examtrust"
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

JWT_SECRET="examtrust-secret-key-2024-very-secure-key"
JWT_EXPIRES_IN="360d"
