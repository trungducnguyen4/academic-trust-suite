# Copy this file to .env on the Oracle VM before running docker compose.
# Do not commit the real .env file.

# Public app URLs
FRONTEND_URL=https://your-app.pages.dev
APP_BASE_URL=https://your-app.pages.dev
CORS_ORIGINS=https://your-app.pages.dev

# Database
MYSQL_DATABASE=examtrust
MYSQL_USER=examtrust
MYSQL_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
MYSQL_ROOT_PASSWORD=CHANGE_ME_STRONG_ROOT_PASSWORD
DATABASE_URL=mysql://examtrust:CHANGE_ME_STRONG_DB_PASSWORD@db:3306/examtrust

# Auth
JWT_SECRET=CHANGE_ME_LONG_RANDOM_SECRET_32_PLUS_CHARS
JWT_EXPIRES_IN=15m

# Mail
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=CHANGE_ME
SMTP_PASS=CHANGE_ME
EMAIL_FROM=ExamTrust <no-reply@example.com>

# Redis is private inside Docker, but still use a password in production.
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD

# AI worker
AI_PROVIDER=openrouter
AI_OLLAMA_URL=http://ollama:11434
AI_OLLAMA_MODEL=gemma3:4b
AI_OLLAMA_TEMPERATURE=0.2
AI_OLLAMA_TOP_P=0.85
AI_OLLAMA_REPEAT_PENALTY=1.1
AI_OLLAMA_NUM_CTX=8192
NVIDIA_API_KEY=CHANGE_ME_NVIDIA_API_KEY
AI_NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
AI_NVIDIA_MODEL=z-ai/glm-5.2
OPENROUTER_API_KEY=CHANGE_ME_OPENROUTER_API_KEY
AI_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
AI_OPENROUTER_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free
AI_OPENROUTER_REASONING_ENABLED=false
AI_OPENROUTER_HTTP_REFERER=https://your-app.pages.dev
AI_OPENROUTER_X_TITLE=ExamTrust
AI_APP_NAME=ExamTrust
AI_DEFAULT_LANGUAGE=vi

# Queue protection
QUEUE_WAITING_THRESHOLD_AUTOSAVE=1000
