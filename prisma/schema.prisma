generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

/// MySQL-compatible schema for Academic Trust Suite

enum CourseTerm {
  TERM_1
  TERM_2
  SUMMER
}

enum ExamMode {
  NORMAL
  LAB
}

enum ExamGradingStrategy {
  HIGHEST
  AVERAGE
  FIRST_ATTEMPT
  LAST_ATTEMPT
}

enum QuestionLifecycleStatus {
  DRAFT
  IN_REVIEW
  PUBLISHED
  ARCHIVED
}

enum QuestionDraftStep {
  INTENT
  CONTENT
  ANSWERS
  CLASSIFICATION
  REVIEW
}

enum QuestionDraftMode {
  MANUAL
  AI_ASSISTED
  DUPLICATE
}

enum AISection {
  CONTENT
  ANSWERS
  EXPLANATION
  CLASSIFICATION
}

enum AIJobStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  REJECTED
}

enum AIReviewStatus {
  PENDING
  APPROVED
  REJECTED
  NEEDS_CHANGES
}

enum CourseStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum EnrollmentStatus {
  ACTIVE
  DROPPED
  COMPLETED
}

enum ExamStatus {
  DRAFT
  PUBLISHED
  ONGOING
  COMPLETED
  ARCHIVED
}

enum SubmissionStatus {
  IN_PROGRESS
  SUBMITTING
  SUBMITTED
  GRADE_PENDING
  GRADED
  FLAGGED
  SUBMIT_FAILED
}

enum ExamInstanceStatus {
  NOT_STARTED
  IN_PROGRESS
  SUBMITTED
  GRADED
  FLAGGED
  EXPIRED
}

enum ScoringNormalization {
  LINEAR
}

enum FocusState {
  FOCUSED
  BLURRED
}

enum AnomalyFlagStatus {
  OPEN
  REVIEWED
  DISMISSED
  CONFIRMED
}

model User {
  id         String    @id @default(uuid())
  email      String    @unique
  password   String
  fullName   String
  role       String    @default("STUDENT") // ADMIN, LECTURER, STUDENT
  studentId  String?   // Only for students
  department String?
  avatar     String?
  status     String    @default("active")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  // relations
  coursesTaught  Course[]         @relation("CourseLecturer")
  examsCreated   Exam[]           @relation("ExamCreator")
  enrollments    Enrollment[]
  submissions    ExamSubmission[] @relation("StudentSubmissions")
  examInstances  ExamInstance[]
  questions      Question[]       @relation("AuthorQuestions")
  createdExamLinks ExamLink[]     @relation("ExamLinkCreator")
  examLinkUsages   ExamLinkUsage[] @relation("ExamLinkUsageUser")
  notifications   Notification[]   @relation("UserNotifications")
  aiReviewedRecords AIGenerationRecord[] @relation("AIReviewUser")
  examSubmissionRegradeLogs ExamSubmissionRegradeLog[] @relation("RegradeReviewer")

  @@map("users")
}

model Course {
  id         String    @id @default(uuid())
  code       String    @unique
  name       String
  academicYear String?
  term       CourseTerm?
  description String?  @db.Text
  credits    Int?
  status     String    @default("draft")
  statusEnum CourseStatus?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  // optional lecturer (User)
  lecturerId String?
  lecturer   User?     @relation("CourseLecturer", fields: [lecturerId], references: [id])

  enrollments Enrollment[]
  exams       Exam[]
  questions   Question[]
  topics      Topic[]
  courseTopics CourseTopic[]
  questionCourseScopes QuestionCourseScope[]

  @@index([code])
  @@index([lecturerId])
  @@map("courses")
}

model Enrollment {
  id        String   @id @default(uuid())
  course    Course   @relation(fields: [courseId], references: [id])
  courseId  String
  student   User     @relation(fields: [studentId], references: [id])
  studentId String
  joinedAt  DateTime @default(now())
  status    String   @default("active")
  statusEnum EnrollmentStatus?

  @@unique([courseId, studentId])
  @@index([studentId])
  @@map("enrollments")
}

model Exam {
  id                     String   @id @default(uuid())
  course                 Course   @relation(fields: [courseId], references: [id])
  courseId               String
  title                  String
  description            String?  @db.Text
  duration               Int      // duration in minutes
  timeLimitMinutes       Int?
  totalPoints            Int?
  passingScore           Int?
  startTime              DateTime?
  endTime                DateTime?
  status                 String   @default("DRAFT") // DRAFT, PUBLISHED, ONGOING, COMPLETED, ARCHIVED
  statusEnum             ExamStatus?
  mode                   ExamMode @default(NORMAL)
  settings               Json?
  maxAttempts            Int?
  gradingStrategy        ExamGradingStrategy?
  reviewSettings         Json?
  questionSelectionConfig Json?
  scoringScale           Int?     @default(10)
  scoringRounding         Int?     @default(2)
  scoringNormalization    ScoringNormalization? @default(LINEAR)
  allowLateSubmission     Boolean? @default(false)
  creatorId              String
  creator                User     @relation("ExamCreator", fields: [creatorId], references: [id])
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  examQuestions  ExamQuestion[]
  submissions    ExamSubmission[]
  examInstances  ExamInstance[]
  links          ExamLink[]
  ipWhitelist    ExamIpWhitelist[]
  accessDeniedLogs ExamAccessDeniedLog[]
  snapshots      ExamSnapshot[]

  @@index([courseId])
  @@index([creatorId])
  @@index([status])
  @@index([gradingStrategy])
  @@map("exams")
}

model ExamIpWhitelist {
  id            String   @id @default(uuid())
  exam          Exam     @relation(fields: [examId], references: [id])
  examId        String
  rule          String   // e.g. single IP or CIDR (192.168.1.10 or 192.168.1.0/24)
  ipVersion     Int?
  normalized    String?
  createdBy     String?
  createdAt     DateTime @default(now())

  @@index([examId])
  @@map("exam_ip_whitelist")
}

model ExamAccessDeniedLog {
  id              String   @id @default(uuid())
  exam            Exam     @relation(fields: [examId], references: [id])
  examId          String
  studentId       String?
  resolvedClientIp String
  remoteIp        String?
  forwardedFor    String?
  userAgent       String?
  reasonCode      String
  reasonMessage   String?
  route           String?
  createdAt       DateTime @default(now())

  @@index([examId])
  @@index([studentId])
  @@map("exam_access_denied_log")
}

model ExamLink {
  id                  String   @id @default(uuid())
  exam                Exam     @relation(fields: [examId], references: [id])
  examId              String
  tokenHash           String   @unique @db.VarChar(128)
  createdBy           String
  creator             User     @relation("ExamLinkCreator", fields: [createdBy], references: [id])
  expiresAt           DateTime?
  maxUses             Int?
  usedCount           Int      @default(0)
  lastUsedAt          DateTime?
  passwordHash        String?  @db.VarChar(255)
  restrictedToCourse  Boolean  @default(false)
  disabled            Boolean  @default(false)
  note                String?  @db.Text
  passwordAttempts    Int      @default(0)
  lockedUntil         DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  usages              ExamLinkUsage[]

  @@index([examId])
  @@index([createdBy])
  @@index([expiresAt])
  @@map("exam_links")
}

model ExamLinkUsage {
  id         String   @id @default(uuid())
  link       ExamLink @relation(fields: [linkId], references: [id])
  linkId     String
  user       User?    @relation("ExamLinkUsageUser", fields: [userId], references: [id])
  userId     String?
  ip         String?  @db.VarChar(64)
  userAgent  String?  @db.Text
  usedAt     DateTime @default(now())

  @@index([linkId])
  @@index([userId])
  @@map("exam_link_usages")
}

model Question {
  id           String   @id @default(uuid())
  type         String   // MULTIPLE_CHOICE, MULTI_SELECT, TRUE_FALSE, SHORT_ANSWER, ESSAY, FILL_IN_BLANK, MATCHING, ORDERING
  content      String   @db.Text
  options      Json?    // array of options or structured JSON
  correctAnswer Json?
  explanation  String?  @db.Text
  difficulty   Int?     @default(1)
  points       Int?     @default(1)
  defaultPoints Decimal? @default(1.0) @db.Decimal(5, 2)
  courseId     String?
  course       Course?  @relation(fields: [courseId], references: [id])
  creatorId    String?
  creator      User?    @relation("AuthorQuestions", fields: [creatorId], references: [id])
  status       QuestionLifecycleStatus @default(DRAFT)
  latestVersionNo Int   @default(1)
  isReusable   Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  exams             ExamQuestion[]
  submissionAnswers SubmissionAnswer[]
  versions          QuestionVersion[]
  statistics        QuestionStatistics[]
  topicLinks        QuestionTopic[]
  courseScopes      QuestionCourseScope[]
  drafts            QuestionDraft[]
  usages            QuestionUsage[]

  @@index([courseId])
  @@index([creatorId])
  @@index([status])
  @@map("questions")
}

model QuestionVersion {
  id            String   @id @default(uuid())
  questionId    String
  question      Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  versionNo     Int
  stem          String   @db.Text
  payload       Json?
  answerKey     Json?
  explanation   String?  @db.Text
  difficulty    Int?
  points        Int?
  metadata      Json?
  aiGenerated   Boolean  @default(false)
  createdBy     String?
  createdAt     DateTime @default(now())

  examItems          ExamQuestion[]
  submissionAnswers  SubmissionAnswer[]
  aiRecords          AIGenerationRecord[]
  statistics         QuestionStatistics?

  @@unique([questionId, versionNo])
  @@index([questionId, createdAt])
  @@index([createdBy])
  @@map("question_versions")
}


model Topic {
  id        String   @id @default(uuid())
  code      String
  name      String
  courseId  String?
  course    Course?  @relation(fields: [courseId], references: [id])
  createdAt DateTime @default(now())

  questionLinks QuestionTopic[]
  courseLinks   CourseTopic[]

  @@index([courseId])
  @@unique([courseId, code])
  @@map("topics")
}

model QuestionTopic {
  questionId String
  topicId    String
  weight     Float?
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  topic      Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@id([questionId, topicId])
  @@index([topicId])
  @@map("question_topics")
}

model CourseTopic {
  courseId String
  topicId  String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  topic    Topic  @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@id([courseId, topicId])
  @@index([topicId])
  @@map("course_topics")
}

model QuestionCourseScope {
  questionId String
  courseId   String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  course     Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@id([questionId, courseId])
  @@index([courseId])
  @@map("question_course_scopes")
}

model QuestionDraft {
  id              String   @id @default(uuid())
  questionId      String?
  question        Question? @relation(fields: [questionId], references: [id], onDelete: SetNull)
  creatorId       String
  mode            QuestionDraftMode
  currentStep     QuestionDraftStep @default(INTENT)
  autosaveVersion Int      @default(1)
  state           Json
  validation      Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  aiRecords       AIGenerationRecord[]

  @@index([creatorId, updatedAt])
  @@index([questionId])
  @@map("question_drafts")
}

model AIGenerationRecord {
  id                String   @id @default(uuid())
  draftId           String?
  draft             QuestionDraft? @relation(fields: [draftId], references: [id], onDelete: SetNull)
  questionVersionId String?
  questionVersion   QuestionVersion? @relation(fields: [questionVersionId], references: [id], onDelete: SetNull)
  section           AISection
  status            AIJobStatus @default(QUEUED)
  reviewStatus      AIReviewStatus @default(PENDING)
  reviewedBy        String?
  reviewer          User?    @relation("AIReviewUser", fields: [reviewedBy], references: [id], onDelete: SetNull)
  reviewedAt        DateTime?
  reviewNotes       String?  @db.Text
  provider          String?
  model             String?
  prompt            Json?
  output            Json?
  safetyFlags       Json?
  errorMessage      String?  @db.Text
  createdAt         DateTime @default(now())
  completedAt       DateTime?

  @@index([draftId, createdAt])
  @@index([questionVersionId])
  @@index([status])
  @@index([reviewStatus])
  @@index([reviewedBy])
  @@map("ai_generation_records")
}

model QuestionUsage {
  id          String   @id @default(uuid())
  questionId  String
  question    Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  contextType String
  contextId   String
  usedAt      DateTime @default(now())
  metrics     Json?

  @@index([questionId, usedAt])
  @@index([contextType, contextId])
  @@map("question_usages")
}

model QuestionStatistics {
  questionVersionId   String   @id
  questionVersion     QuestionVersion @relation(fields: [questionVersionId], references: [id], onDelete: Cascade)
  questionId          String
  question            Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  totalAttempts       Int      @default(0)
  correctAttempts     Int      @default(0)
  incorrectAttempts   Int      @default(0)
  skippedAttempts     Int      @default(0)
  pValue              Decimal? @db.Decimal(5, 4)
  difficultyIndex     Decimal? @db.Decimal(5, 4)
  discriminationIndex Decimal? @db.Decimal(5, 4)
  lastRecomputedAt    DateTime @default(now())

  @@index([questionId])
  @@map("question_statistics")
}

model ExamQuestion {
  id         String   @id @default(uuid())
  exam       Exam     @relation(fields: [examId], references: [id])
  examId     String
  question   Question @relation(fields: [questionId], references: [id])
  questionId String
  questionVersionId String?
  questionVersion   QuestionVersion? @relation(fields: [questionVersionId], references: [id])
  orderIndex Int
  points     Int?     @default(1)
  assignedScore Decimal? @default(1.0) @db.Decimal(7, 2)
  weight     Decimal? @db.Decimal(5, 2)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([examId, questionId])
  @@unique([examId, orderIndex])
  @@index([examId])
  @@index([examId, orderIndex])
  @@index([questionVersionId])
  @@map("exam_questions")
}

model ExamSubmission {
  id           String    @id @default(uuid())
  exam         Exam      @relation(fields: [examId], references: [id])
  examId       String
  examInstanceId String?
  examInstance  ExamInstance? @relation(fields: [examInstanceId], references: [id])
  student      User      @relation("StudentSubmissions", fields: [studentId], references: [id])
  studentId    String
  attemptNo    Int       @default(1) // For versioning multiple attempts per (exam, student) pair
  status       String    @default("IN_PROGRESS") // IN_PROGRESS, SUBMITTING, SUBMITTED, GRADE_PENDING, GRADED, FLAGGED, SUBMIT_FAILED
  statusEnum   SubmissionStatus?
  version      Int       @default(0)
  submitLockedAt DateTime?
  lastAutosaveAt DateTime?
  lastActivityAt DateTime?
  submitIdempotencyKey String? @db.VarChar(255)
  finalSnapshotVersion Int?
  examSnapshotId String?
  examSnapshot   ExamSnapshot? @relation(fields: [examSnapshotId], references: [id])
  score        Int?
  startedAt    DateTime?
  submittedAt  DateTime?
  gradedAt     DateTime?
  createdAt    DateTime  @default(now())

  answers      SubmissionAnswer[]
  regradeLogs  ExamSubmissionRegradeLog[]
  proctoring   ProctoringSession?

  @@unique([examId, studentId, attemptNo])
  @@index([examId])
  @@index([studentId])
  @@index([examInstanceId])
  @@index([examId, studentId, status])
  @@index([studentId, status, createdAt])
  @@index([submitIdempotencyKey])
  @@map("exam_submissions")
}

model ExamSubmissionRegradeLog {
  id                String   @id @default(uuid())
  submission         ExamSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  submissionId       String
  submissionAnswerId String
  submissionAnswer   SubmissionAnswer @relation(fields: [submissionAnswerId], references: [id], onDelete: Cascade)
  reviewerId         String
  reviewer           User     @relation("RegradeReviewer", fields: [reviewerId], references: [id], onDelete: Restrict)
  previousPoints     Int?
  newPoints          Int?
  previousFeedback   String?  @db.Text
  newFeedback        String?  @db.Text
  reason             String?  @db.Text
  createdAt          DateTime @default(now())

  @@index([submissionId, createdAt])
  @@index([submissionAnswerId])
  @@index([reviewerId])
  @@map("exam_submission_regrade_logs")
}

model ExamInstance {
  id             String   @id @default(uuid())
  examId         String
  exam           Exam     @relation(fields: [examId], references: [id])
  studentId      String
  student        User     @relation(fields: [studentId], references: [id])
  examSnapshotId String?
  examSnapshot   ExamSnapshot? @relation(fields: [examSnapshotId], references: [id], onDelete: SetNull)
  status         ExamInstanceStatus @default(NOT_STARTED)
  startedAt      DateTime?
  submittedAt    DateTime?
  lastActivityAt DateTime?
  ipAddress      String?  @db.VarChar(64)
  userAgent      String?  @db.Text
  encryptedPayload Bytes?
  payloadChecksum String? @db.VarChar(64)
  snapshotPayload Json?
  randomizationSeed String? @db.VarChar(64)
  questionOrder  Json?
  rawScore       Decimal? @db.Decimal(7, 2)
  maxRawScore    Decimal? @db.Decimal(7, 2)
  normalizedScore Decimal? @db.Decimal(5, 2)
  anomalyScore   Decimal? @db.Decimal(5, 2)
  suspiciousFlag Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  submissions    ExamSubmission[]
  interactionLogs InteractionLog[]
  tabSwitchEvents TabSwitchEvent[]
  focusEvents     FocusEvent[]
  anomalyFlags    AnomalyFlag[]

  @@unique([examId, studentId])
  @@index([examId])
  @@index([studentId])
  @@index([examSnapshotId])
  @@map("exam_instances")
}

model InteractionLog {
  id             String   @id @default(uuid())
  examInstanceId String
  examInstance   ExamInstance @relation(fields: [examInstanceId], references: [id], onDelete: Cascade)
  eventType      String
  payload        Json?
  createdAt      DateTime @default(now())

  @@index([examInstanceId, createdAt])
  @@map("interaction_logs")
}

model TabSwitchEvent {
  id             String   @id @default(uuid())
  examInstanceId String
  examInstance   ExamInstance @relation(fields: [examInstanceId], references: [id], onDelete: Cascade)
  occurredAt     DateTime @default(now())
  durationMs     Int?
  fromTab        String?
  toTab          String?

  @@index([examInstanceId, occurredAt])
  @@map("tab_switch_events")
}

model FocusEvent {
  id             String   @id @default(uuid())
  examInstanceId String
  examInstance   ExamInstance @relation(fields: [examInstanceId], references: [id], onDelete: Cascade)
  occurredAt     DateTime @default(now())
  focusState     FocusState
  reason         String?

  @@index([examInstanceId, occurredAt])
  @@map("focus_events")
}

model AnomalyFlag {
  id             String   @id @default(uuid())
  examInstanceId String
  examInstance   ExamInstance @relation(fields: [examInstanceId], references: [id], onDelete: Cascade)
  kind           String
  score          Decimal? @db.Decimal(5, 2)
  status         AnomalyFlagStatus @default(OPEN)
  reviewerId     String?
  notes          String?  @db.Text
  createdAt      DateTime @default(now())
  reviewedAt     DateTime?

  @@index([examInstanceId])
  @@index([status])
  @@map("anomaly_flags")
}

model SubmissionAnswer {
  id               String         @id @default(uuid())
  submission       ExamSubmission @relation(fields: [submissionId], references: [id])
  submissionId     String
  question         Question       @relation(fields: [questionId], references: [id])
  questionId       String
  questionVersionId String?
  questionVersion   QuestionVersion? @relation(fields: [questionVersionId], references: [id])
  questionSnapshotId String?
  questionSnapshot   QuestionSnapshot? @relation(fields: [questionSnapshotId], references: [id])
  sequence         Int            @default(1)
  clientBatchId    String?        @db.VarChar(255)
  serverVersion    Int            @default(0)
  answer           Json
  isCorrect        Boolean?
  pointsAwarded    Int?
  feedback         String?        @db.Text
  timeTaken        Int?           // in seconds
  updatedAt        DateTime       @updatedAt

  @@unique([submissionId, questionId])
  @@index([submissionId])
  @@index([questionId])
  @@index([submissionId, questionId, sequence])
  @@index([submissionId, questionVersionId])
  @@index([questionVersionId])
  regradeLogs      ExamSubmissionRegradeLog[]
  @@map("submission_answers")
}

model ExamSnapshot {
  id         String   @id @default(uuid())
  examId     String
  exam       Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  title      String
  payload    Json?    // full exam-level payload (settings, static metadata)
  createdBy  String?
  createdAt  DateTime @default(now())
  publishedAt DateTime?

  questions  ExamQuestionSnapshot[]
  examInstances ExamInstance[]
  submissions ExamSubmission[]
  @@index([examId])
  @@map("exam_snapshots")
}

model ExamQuestionSnapshot {
  id                String   @id @default(uuid())
  examSnapshotId    String
  examSnapshot      ExamSnapshot @relation(fields: [examSnapshotId], references: [id], onDelete: Cascade)
  questionId        String
  questionVersionId String?
  questionSnapshotId String?
  orderIndex        Int
  points            Int?
  assignedScore     Decimal? @db.Decimal(7, 2)
  payload           Json?    // question payload copied at snapshot time

  questionSnapshot  QuestionSnapshot? @relation(fields: [questionSnapshotId], references: [id])

  @@index([examSnapshotId])
  @@index([questionId])
  @@map("exam_question_snapshots")
}

model QuestionSnapshot {
  id               String   @id @default(uuid())
  originalQuestionId String
  questionVersionId String
  payload          Json?    // full question payload (stem, options, answerKey, explanation)
  createdAt        DateTime @default(now())

  examQuestionLinks ExamQuestionSnapshot[]
  submissionAnswers SubmissionAnswer[]

  @@index([originalQuestionId])
  @@index([questionVersionId])
  @@map("question_snapshots")
}

model ProctoringSession {
  id             String   @id @default(uuid())
  submission     ExamSubmission @relation(fields: [submissionId], references: [id])
  submissionId   String   @unique
  ipAddress      String?
  tabSwitchCount Int?     @default(0)
  mouseAnomalies Int?     @default(0)
  flaggedStatus  String?
  integrityScore Float?
  createdAt      DateTime @default(now())

  logs IntegrityLog[]

  @@map("proctoring_sessions")
}

model IntegrityLog {
  id            String   @id @default(uuid())
  proctoring    ProctoringSession @relation(fields: [proctoringId], references: [id])
  proctoringId  String
  eventType     String
  details       String?
  timestamp     DateTime @default(now())

  @@index([proctoringId])
  @@map("integrity_logs")
}

model Notification {
  id          String   @id @default(uuid())
  recipientId String
  recipient   User     @relation("UserNotifications", fields: [recipientId], references: [id], onDelete: Cascade)
  kind        String
  title       String
  message     String   @db.Text
  link        String?
  priority    String   @default("normal")
  metadata    Json?
  isRead      Boolean  @default(false)
  readAt      DateTime?
  createdAt   DateTime @default(now())

  @@index([recipientId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

/// Durable event store for critical events that must be persisted and replayable
model EventStore {
  id         String   @id @default(uuid())
  dedupId    String?  @db.VarChar(255) // optional client-supplied id for idempotency
  kind       String
  payload    Json
  critical   Boolean  @default(false)
  status     String   @default("PENDING") // PENDING, PROCESSING, PROCESSED, FAILED
  attempts   Int      @default(0)
  lastError  String?  @db.Text
  source     String?  // e.g. 'api-instance'
  createdAt  DateTime @default(now())
  processedAt DateTime?

  @@index([dedupId])
  @@index([kind])
  @@map("event_store")
}
